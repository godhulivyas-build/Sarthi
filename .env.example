# Gemini AI (for chat assistant)
GEMINI_API_KEY=

# OpenWeatherMap — free tier: 1000 calls/day
# https://openweathermap.org/api
VITE_OWM_API_KEY=

# data.gov.in — for live mandi/commodity prices
# https://data.gov.in/
VITE_DATAGOV_API_KEY=

# Google Maps — enable "Maps JavaScript API" + "Directions API" in Google Cloud for this key.
# With key: full embedded map, driving route polyline, draggable pickup/drop pins.
# Without key: OpenStreetMap + OSRM public demo routing (free, not for heavy production load).
VITE_GOOGLE_MAPS_API_KEY=

# Razorpay — optional; leave empty to use the mock payment + split-ledger demo only.
VITE_RAZORPAY_KEY_ID=
