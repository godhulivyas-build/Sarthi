# Gemini AI (for chat assistant)
GEMINI_API_KEY=

# OpenWeatherMap — free tier: 1000 calls/day
# https://openweathermap.org/api
VITE_OWM_API_KEY=

# data.gov.in — for live mandi/commodity prices
# https://data.gov.in/
VITE_DATAGOV_API_KEY=

# Google Maps (JavaScript API + Directions for V2 booking). Optional: UI degrades without a key.
VITE_GOOGLE_MAPS_API_KEY=

# Razorpay — optional; leave empty to use the mock payment + split-ledger demo only.
VITE_RAZORPAY_KEY_ID=
